theorem lean_ai_conj_pair_context (P Q : Prop) (hP : P) (hQ : Q) (R S : Prop) (hRS : R ∧ S) : P ∧ Q := by
  have child_left : P := by
    exact hP
  have child_right : Q := by
    exact hQ
