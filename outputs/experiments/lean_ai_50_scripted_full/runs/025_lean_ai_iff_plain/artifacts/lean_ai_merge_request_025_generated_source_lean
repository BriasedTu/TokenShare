import Init
set_option autoImplicit false
namespace TokenShareGenerated
theorem lean_ai_iff_plain (P Q : Prop) (hpq : P → Q) (hqp : Q → P) : P ↔ Q := by
  have child_forward : P → Q := by
    exact hpq
  have child_backward : Q → P := by
    exact hqp
  exact Iff.intro child_forward child_backward
end TokenShareGenerated
